{
    "open_login_page": {
      "type": "open_url",
      "path": "/"
    },
    "input_username": {
      "type": "input",
      "selector_type": "id",
      "selector": "user-name",
      "value": "standard_user"
    },
    "input_password": {
      "type": "input",
      "selector_type": "id",
      "selector": "password",
      "value": "secret_sauce"
    },
    "click_login": {
      "type": "click",
      "selector_type": "id",
      "selector": "login-button"
    },
    "verify_dashboard": {
      "type": "assert_url_contains",
      "expected": "inventory"
    },
    "click_add_cart": {
      "type": "click",
      "selector_type": "id",
      "selector": "add-to-cart-sauce-labs-backpack"
    },
    "verify_cart": {
      "type": "assert_text",
      "selector_type": "css",
      "selector": ".shopping_cart_badge",
      "expected": "1"
    },
    "click_menu": {
      "type": "click",
      "selector_type": "id",
      "selector": "react-burger-menu-btn"
    },
    "click_logout": {
      "type": "click",
      "selector_type": "id",
      "selector": "logout_sidebar_link"
    },
    "verify_login_page": {
      "type": "assert_url_contains",
      "expected": "saucedemo.com"
    }
  }