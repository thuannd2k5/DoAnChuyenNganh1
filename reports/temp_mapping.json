{
  "login_success": {
    "type": "sequence",
    "steps": [
      "input_username",
      "input_password",
      "click_login",
      "verify_login_success"
    ]
  },
  "add_item": {
    "type": "click",
    "selector": "#add-to-cart-sauce-labs-backpack",
    "selector_type": "css"
  },
  "add_failed": {
    "type": "assert_url_contains",
    "expected": "error"
  },
  "open_cart": {
    "type": "click",
    "selector": ".shopping_cart_link",
    "selector_type": "css"
  },
  "verify_cart": {
    "type": "assert_url_contains",
    "expected": "cart"
  },
  "input_username": {
    "type": "input",
    "selector": "#user-name",
    "selector_type": "css",
    "value": "standard_user"
  },
  "input_password": {
    "type": "input",
    "selector": "#password",
    "selector_type": "css",
    "value": "secret_sauce"
  },
  "click_login": {
    "type": "click",
    "selector": "#login-button",
    "selector_type": "css"
  },
  "verify_login_success": {
    "type": "assert_url_contains",
    "expected": "inventory"
  }
}