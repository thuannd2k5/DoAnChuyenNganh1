{
  "login_success": [
    {
      "type": "input",
      "selector_type": "id",
      "selector": "user-name",
      "value": "{{user-name}}"
    },
    {
      "type": "input",
      "selector_type": "id",
      "selector": "password",
      "value": "{{password}}"
    },
    {
      "type": "click",
      "selector_type": "id",
      "selector": "login-button"
    }
  ],
  "select_product": [
    {
      "type": "click",
      "selector_type": "css",
      "selector": ".inventory_item:nth-child(1) .inventory_item_name"
    }
  ],
  "add_to_cart": [
    {
      "type": "click",
      "selector_type": "css",
      "selector": ".btn_inventory"
    }
  ],
  "go_to_cart": [
    {
      "type": "click",
      "selector_type": "id",
      "selector": "shopping_cart_container"
    }
  ],
  "checkout_start": [
    {
      "type": "click",
      "selector_type": "id",
      "selector": "checkout"
    }
  ],
  "input_checkout_info": [
    {
      "type": "input",
      "selector_type": "id",
      "selector": "first-name",
      "value": "{{first-name}}"
    },
    {
      "type": "input",
      "selector_type": "id",
      "selector": "last-name",
      "value": "{{last-name}}"
    },
    {
      "type": "input",
      "selector_type": "id",
      "selector": "postal-code",
      "value": "{{postal-code}}"
    },
    {
      "type": "click",
      "selector_type": "id",
      "selector": "continue"
    }
  ],
  "click_finish": [
    {
      "type": "click",
      "selector_type": "id",
      "selector": "finish"
    }
  ]
}